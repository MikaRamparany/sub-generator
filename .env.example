# Groq API key (required)
GROQ_API_KEY=your_groq_api_key_here

# STT models — two separate models for quality differentiation
# Fast mode: uses whisper-large-v3-turbo (faster, slightly less accurate)
# High quality mode: uses whisper-large-v3 (slower, more accurate, temperature=0)
# Set both to the same model if you only have access to one.
GROQ_STT_FAST_MODEL=whisper-large-v3-turbo
GROQ_STT_QUALITY_MODEL=whisper-large-v3

# Translation LLM
GROQ_TRANSLATION_MODEL=llama-3.3-70b-versatile

# Limits
MAX_UPLOAD_MB=2048
MAX_API_AUDIO_CHUNK_MB=25

# Paths (leave empty to use ~/.subtitle-generator/tmp)
TEMP_DIR=

# Logging
LOG_LEVEL=INFO

# Set to true to keep intermediate audio/chunk files for debugging
DEBUG_KEEP_TEMP_FILES=false
